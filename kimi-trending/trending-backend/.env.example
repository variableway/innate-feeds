# Database Configuration
DB_DRIVER=sqlite
DB_NAME=trending.db
DB_HOST=localhost
DB_PORT=5432
DB_USER=trending
DB_PASSWORD=secret
DB_SSL_MODE=disable

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8080
API_READ_TIMEOUT=30
API_WRITE_TIMEOUT=30

# GitHub API
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

# Product Hunt API
PRODUCTHUNT_TOKEN=
PRODUCTHUNT_API_URL=https://api.producthunt.com/v2/api/graphql

# Scheduler
FETCH_INTERVAL=3600

# TUI
TUI_REFRESH_RATE=5
