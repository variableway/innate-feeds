# Innate Hub Configuration

# ==========================================
# Required
# ==========================================
HUB_PASSWORD=your-secure-password

# ==========================================
# Optional: General
# ==========================================
# HTTP port (default: 8080)
HUB_PORT=8080

# Database: SQLite file path or PostgreSQL DSN
# SQLite (default): hub.db
# PostgreSQL (e.g. InsForge): postgres://user:pass@host:5432/db?sslmode=require
HUB_DB_PATH=hub.db

# Log level: DEBUG, INFO, WARN, ERROR
HUB_LOG_LEVEL=INFO

# Pull interval in seconds (default: 1800 = 30 min)
HUB_PULL_INTERVAL=1800

# TrendRadar data directory inside container
# Default mounts ./TrendRadar/output/news to /data/trendradar
TRENDRADAR_DATA_DIR=/data/trendradar

# ==========================================
# Optional: OIDC Authentication
# ==========================================
# When OIDC is configured, users can login via SSO (e.g. Google, GitHub, Authelia).
# If both password and OIDC are empty, authentication is disabled (not recommended).
#
# FUSION_OIDC_ISSUER=https://accounts.google.com
# FUSION_OIDC_CLIENT_ID=your-client-id
# FUSION_OIDC_CLIENT_SECRET=your-client-secret
# FUSION_OIDC_REDIRECT_URI=http://localhost:8080/api/oidc/callback
# FUSION_OIDC_ALLOWED_USER=your@email.com

# ==========================================
# Optional: PostgreSQL (only needed for postgres Docker profile)
# ==========================================
POSTGRES_USER=hub
POSTGRES_PASSWORD=hub
POSTGRES_DB=hub

# ==========================================
# Optional: Semantic Search (Embedding)
# ==========================================
# Provider: "openai", "ollama", or empty (disabled)
HUB_EMBEDDER_PROVIDER=

# Model name (provider-specific)
# OpenAI: text-embedding-3-small (1536d), text-embedding-3-large (3072d)
# Ollama: nomic-embed-text (768d), mxbai-embed-large (1024d)
HUB_EMBEDDER_MODEL=

# API base URL (optional, uses provider default if empty)
# OpenAI default: https://api.openai.com/v1
# Ollama default: http://localhost:11434
HUB_EMBEDDER_BASE_URL=

# API key (required for OpenAI)
HUB_EMBEDDER_API_KEY=
