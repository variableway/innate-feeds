{
  "productName": "Trending Aggregator",
  "version": "1.0.0",
  "identifier": "com.trending-aggregator.app",
  "build": {
    "frontendDist": "../trending-web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../trending-web && npm run dev",
    "beforeBuildCommand": "cd ../trending-web && npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Trending Aggregator",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "withGlobalTauri": false,
    "security": {
      "csp": null,
      "capabilities": []
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "dmg", "msi", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
